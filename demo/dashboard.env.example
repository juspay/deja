# Every environment variable the Deja dashboard (deja-orchestrator) consumes,
# with where each value ultimately flows. The compose file
# (docker-compose.dashboard.yml) reads these; copy to demo/.env (or export
# them) and run:
#
#   docker compose -f demo/docker-compose.dashboard.yml up -d --build
#
# Downstream flow: the sandbox driver renders the DEJA_S3_* and minted ECR
# token into each run's Helm values -> the chart turns them into the run
# namespace's agent.toml Secret / dockerconfigjson Secret -> the replay agent
# and pods consume them there. Router-level configuration is NOT env here: it
# lives in replay-sandbox/chart, overridable per run.

# ── Core service ────────────────────────────────────────────────────────────
# Bind address inside the container and on-disk run state (set in compose).
#   HARNESS_BIND=0.0.0.0:8070
#   HARNESS_STATE_DIR=/var/lib/deja
# Postgres for runs/stages/verdicts/scorecards (compose provides the pg
# container and sets this):
#   DEJA_DB_URL=postgres://deja:deja@pg:5432/deja

# Bearer token required on mutating API calls; also what sandbox agents
# present on stage/verdict callbacks (flows into each run's values as
# callback.token). Enter this same value in the dashboard's "service token"
# box before scheduling runs from the browser.
DEJA_API_SERVICE_TOKEN=deja-local-token

# ── Kubernetes access ───────────────────────────────────────────────────────
# Kubeconfig mounted into the container. Must point at an API server address
# reachable FROM the container — a host kubeconfig's 127.0.0.1 is not; see
# ~/.kube/deja-dashboard-config (server rewritten to host.docker.internal).
DEJA_KUBECONFIG=~/.kube/deja-dashboard-config

# ── Sandbox driver (DEJA_SANDBOX=helm is set in compose) ────────────────────
# URL sandbox pods use to call back into this dashboard for stage/verdict.
DEJA_CALLBACK_BASE_URL=http://host.docker.internal:8070
# Seconds to wait for the agent's verdict before failing a run + cleanup.
DEJA_SANDBOX_RUN_DEADLINE_SECS=1800
# Set to 1 to keep a run's namespace after it finishes (debugging).
DEJA_SANDBOX_KEEP=

# ── Candidate images (ECR) ──────────────────────────────────────────────────
# Repository CI pushes candidate router images to. A run's branch/commit/tag
# resolves to this repo with tag = ref ('/' mapped to '-').
DEJA_CANDIDATE_IMAGE_REPO=000000000000.dkr.ecr.ap-south-1.amazonaws.com/hyperswitch-router
DEJA_CANDIDATE_IMAGE_TAG_TEMPLATE={ref}
# Private registry for optional helper images. Router uses the full ECR
# repository above; replay agent and Superposition use full image references.
# Defaults to the candidate repo's host.
DEJA_ECR_REGISTRY=000000000000.dkr.ecr.ap-south-1.amazonaws.com
# Agent image. Must be pullable by the target cluster. docker compose also
# builds/tags Dockerfile.replay-agent with this name.
DEJA_AGENT_IMAGE=deja-replay-agent:latest
# Post-deploy escape hatch: raw YAML merged last into per-run helm values.
# Use router.envOverrides here for router deployment envs that must differ from
# the replay-safe chart defaults. For a shell export:
#   export DEJA_SANDBOX_EXTRA_VALUES=$'router:\n  envOverrides:\n    ROUTER__SERVER__BASE_URL: "https://replay.example.internal/api"'
DEJA_SANDBOX_EXTRA_VALUES=
# AWS credentials for minting 12h ECR pull tokens per run (delivered into
# each run namespace as a dockerconfigjson Secret referenced by every pod).
# LEAVE EMPTY ON EKS — the node IAM role authorizes pulls natively.
DEJA_ECR_ACCESS_KEY_ID=
DEJA_ECR_SECRET_ACCESS_KEY=
# Required with temporary AWS/STS credentials; leave empty for long-lived keys
# or node IAM based pulls.
DEJA_ECR_SESSION_TOKEN=
DEJA_ECR_REGION=

# ── Router secret handling ───────────────────────────────────────────────────
# Default replay runs use chart-minted plaintext dummy secrets, so leave this
# false/empty. Set true only when using copied or supplied KMS ciphertext
# secrets, including replaySecrets.dummyValue.
DEJA_KMS_ENABLED=false

# ── Recording + report storage (one S3 location for both) ──────────────────
# Recordings are read from sessions/v1/{recording_id}/ at the BUCKET ROOT
# (the compactor layout ignores the prefix); the agent uploads reports
# (scorecard.json + artifacts) under {prefix}/runs/{run_id}/. These creds
# flow into each run's agent.toml.
DEJA_S3_REGION=us-east-1
DEJA_S3_BUCKET=deja-recordings
DEJA_S3_PREFIX=deja/v1
# Endpoint only for MinIO/non-AWS; must be reachable from sandbox pods.
DEJA_S3_ENDPOINT=
DEJA_S3_ACCESS_KEY=
DEJA_S3_SECRET_KEY=
# Required with temporary AWS/STS credentials.
DEJA_S3_SESSION_TOKEN=
